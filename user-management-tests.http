### ========== USER MANAGEMENT ENDPOINTS TESTS ==========
@baseUrl = http://localhost:5000/api

### ------------------------------------------------------------
### 1. PRE-REQUISITES – REPLACE with real values
### ------------------------------------------------------------
@sysAdminToken = YOUR_SYS_ADMIN_TOKEN_HERE
@orgAdminToken = YOUR_ORG_ADMIN_TOKEN_HERE
@validOrgId = VALID_ORGANIZATION_ID_HERE
@invalidOrgId = 67c4a8b9f2e3d4c5e6789999
@validDeptId = VALID_DEPARTMENT_ID_HERE (belongs to the organization above)
@otherOrgDeptId = DEPARTMENT_ID_FROM_ANOTHER_ORGANIZATION

### ============================================================
### ORGADMIN MANAGEMENT (SysAdmin only)
### ============================================================

### TC-UM-01: Create OrgAdmin (Happy Path)
# @name createOrgAdmin
POST {{baseUrl}}/users/org-admins
Authorization: Bearer {{sysAdminToken}}
Content-Type: application/json

{
  "fullName": "Org Admin One",
  "email": "orgadmin1@example.com",
  "password": "Pass123",
  "organizationId": "{{validOrgId}}"
}

### Store created OrgAdmin ID
@orgAdminId = {{createOrgAdmin.response.body._id}}

### TC-UM-02: Create OrgAdmin – Missing organizationId
POST {{baseUrl}}/users/org-admins
Authorization: Bearer {{sysAdminToken}}
Content-Type: application/json

{
  "fullName": "No Org",
  "email": "noorg@example.com",
  "password": "Pass123"
}

### TC-UM-03: Create OrgAdmin – Invalid organizationId
POST {{baseUrl}}/users/org-admins
Authorization: Bearer {{sysAdminToken}}
Content-Type: application/json

{
  "fullName": "Bad Org",
  "email": "badorg@example.com",
  "password": "Pass123",
  "organizationId": "{{invalidOrgId}}"
}

### TC-UM-04: Create OrgAdmin – Duplicate email (run after TC-UM-01)
POST {{baseUrl}}/users/org-admins
Authorization: Bearer {{sysAdminToken}}
Content-Type: application/json

{
  "fullName": "Duplicate",
  "email": "orgadmin1@example.com",
  "password": "AnotherPass",
  "organizationId": "{{validOrgId}}"
}

### TC-UM-07: Get all OrgAdmins
GET {{baseUrl}}/users/org-admins
Authorization: Bearer {{sysAdminToken}}

### TC-UM-05: OrgAdmin tries to create OrgAdmin (should fail)
POST {{baseUrl}}/users/org-admins
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "fullName": "Not Allowed",
  "email": "notallowed@example.com",
  "password": "Pass123",
  "organizationId": "{{validOrgId}}"
}

### TC-UM-08: OrgAdmin tries to GET OrgAdmins (should fail)
GET {{baseUrl}}/users/org-admins
Authorization: Bearer {{orgAdminToken}}

### TC-UM-09: Update OrgAdmin (Happy Path)
PUT {{baseUrl}}/users/org-admins/{{orgAdminId}}
Authorization: Bearer {{sysAdminToken}}
Content-Type: application/json

{
  "fullName": "Updated Org Admin Name",
  "email": "updatedorg@example.com"
}

### TC-UM-10: Update non-existent OrgAdmin
PUT {{baseUrl}}/users/org-admins/{{invalidOrgId}}
Authorization: Bearer {{sysAdminToken}}
Content-Type: application/json

{
  "fullName": "No Exist"
}

### TC-UM-11: Update a non-OrgAdmin user (e.g., citizen)
# First get a citizen ID, then use it here
PUT {{baseUrl}}/users/org-admins/CITIZEN_USER_ID
Authorization: Bearer {{sysAdminToken}}
Content-Type: application/json

{
  "fullName": "Try to update citizen"
}

### TC-UM-12: OrgAdmin tries to update OrgAdmin (should fail)
PUT {{baseUrl}}/users/org-admins/{{orgAdminId}}
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "fullName": "Hacked"
}

### TC-UM-13: Deactivate OrgAdmin (Happy Path)
PUT {{baseUrl}}/users/org-admins/{{orgAdminId}}/deactivate
Authorization: Bearer {{sysAdminToken}}

### TC-UM-14: Deactivate already deactivated OrgAdmin
PUT {{baseUrl}}/users/org-admins/{{orgAdminId}}/deactivate
Authorization: Bearer {{sysAdminToken}}

### TC-UM-15: Deactivate non-existent OrgAdmin
PUT {{baseUrl}}/users/org-admins/{{invalidOrgId}}/deactivate
Authorization: Bearer {{sysAdminToken}}

### TC-UM-16: OrgAdmin tries to deactivate OrgAdmin (should fail)
PUT {{baseUrl}}/users/org-admins/{{orgAdminId}}/deactivate
Authorization: Bearer {{orgAdminToken}}

### ============================================================
### DEPTADMIN MANAGEMENT (OrgAdmin only)
### ============================================================

### TC-UM-17: Create DeptAdmin (Happy Path)
# @name createDeptAdmin
POST {{baseUrl}}/users/dept-admins
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "fullName": "Dept Admin One",
  "email": "deptadmin1@example.com",
  "password": "Pass123",
  "departmentId": "{{validDeptId}}"
}

### Store created DeptAdmin ID
@deptAdminId = {{createDeptAdmin.response.body._id}}

### TC-UM-18: Create DeptAdmin – Department not found
POST {{baseUrl}}/users/dept-admins
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "fullName": "Bad Dept",
  "email": "baddept@example.com",
  "password": "Pass123",
  "departmentId": "{{invalidOrgId}}"
}

### TC-UM-19: Create DeptAdmin – Department belongs to different organization
POST {{baseUrl}}/users/dept-admins
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "fullName": "Wrong Org",
  "email": "wrongorg@example.com",
  "password": "Pass123",
  "departmentId": "{{otherOrgDeptId}}"
}

### TC-UM-20: SysAdmin tries to create DeptAdmin (should fail)
POST {{baseUrl}}/users/dept-admins
Authorization: Bearer {{sysAdminToken}}
Content-Type: application/json

{
  "fullName": "SysAdmin Trying",
  "email": "sysadmin@example.com",
  "password": "Pass123",
  "departmentId": "{{validDeptId}}"
}

### TC-UM-21: Get all DeptAdmins (OrgAdmin)
GET {{baseUrl}}/users/dept-admins
Authorization: Bearer {{orgAdminToken}}

### TC-UM-22: SysAdmin tries to get DeptAdmins (should fail)
GET {{baseUrl}}/users/dept-admins
Authorization: Bearer {{sysAdminToken}}

### TC-UM-23: Update DeptAdmin (Happy Path – change department)
# First create another department in same organization, then use its ID
@newDeptId = ANOTHER_VALID_DEPT_ID_IN_SAME_ORG
PUT {{baseUrl}}/users/dept-admins/{{deptAdminId}}
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "fullName": "Updated DeptAdmin Name",
  "email": "updateddept@example.com",
  "departmentId": "{{newDeptId}}"
}

### TC-UM-24: Update DeptAdmin with department from different organization
PUT {{baseUrl}}/users/dept-admins/{{deptAdminId}}
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "departmentId": "{{otherOrgDeptId}}"
}

### TC-UM-25: OrgAdmin tries to update DeptAdmin from different organization
# Get a DeptAdmin ID from another organization (manually)
PUT {{baseUrl}}/users/dept-admins/DEPTADMIN_FROM_OTHER_ORG
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "fullName": "Hack Attempt"
}

### TC-UM-26: Update non-existent DeptAdmin
PUT {{baseUrl}}/users/dept-admins/{{invalidOrgId}}
Authorization: Bearer {{orgAdminToken}}
Content-Type: application/json

{
  "fullName": "No Exist"
}

### TC-UM-27: Deactivate DeptAdmin (Happy Path)
PUT {{baseUrl}}/users/dept-admins/{{deptAdminId}}/deactivate
Authorization: Bearer {{orgAdminToken}}

### TC-UM-28: Deactivate already deactivated DeptAdmin
PUT {{baseUrl}}/users/dept-admins/{{deptAdminId}}/deactivate
Authorization: Bearer {{orgAdminToken}}

### TC-UM-29: OrgAdmin tries to deactivate DeptAdmin from different organization
PUT {{baseUrl}}/users/dept-admins/DEPTADMIN_FROM_OTHER_ORG/deactivate
Authorization: Bearer {{orgAdminToken}}

### TC-UM-30: SysAdmin tries to deactivate DeptAdmin (should fail)
PUT {{baseUrl}}/users/dept-admins/{{deptAdminId}}/deactivate
Authorization: Bearer {{sysAdminToken}}